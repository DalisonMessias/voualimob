rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- REUSABLE HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      let email = request.auth.token.email != null ? request.auth.token.email.lower() : (request.auth.token.get('email', '').lower());
      return isSignedIn() && (
        email == "contato.ifomee@gmail.com" ||
        email == "dalison.messias@outlook.com" ||
        (exists(/databases/$(database)/documents/settings/global) && 
         get(/databases/$(database)/documents/settings/global).data.get('adminEmail', '').lower() == email)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- COLLECTION RULES ---

    // 1. SETTINGS COLLECTION
    match /settings/{settingId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // 2. USER REGISTRATION COLLECTION
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 3. PASSENGERS / CLIENTS COLLECTION
    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(clientId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 4. CONDUTORES / DRIVERS COLLECTION
    match /drivers/{driverId} {
      allow read: if true; 
      allow create, update: if isOwner(driverId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 5. CORRIDAS / RIDES ORDER SESSIONS
    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      // 6. SUB-COLLECTION CHATS MESSAGES INSIDE RIDES
      match /chats/{msgId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // 7. CONTRACTS COLLECTION
    match /contracts/{contractId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // 8. CONTRACT ACCEPTANCES LOGS
    match /contractAcceptances/{logId} {
      allow read, write: if isAdmin();
    }

    // 9. FINANCIAL TRANSACTIONS COLLECTION
    match /financial_transactions/{txId} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // 10. SUPPORT TICKETS
    match /support_tickets/{ticketId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().userId == request.auth.uid);
      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
        allow create: if isAdmin() || (isSignedIn() && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid);
      }
    }
  }
}
